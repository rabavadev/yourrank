# Required isolated environment. The suite rejects yourrank.site.
E2E_BASE_URL=http://127.0.0.1:8787

# Required acknowledgement because the suite creates and deletes data.
E2E_ALLOW_MUTATIONS=1

# Optional: a Telegram bot token from @BotFather.
# If set, the suite will connect the bot, create custom commands, and send a webhook update.
E2E_TELEGRAM_BOT_TOKEN=
