{
  "name": "yourrank-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:legacy": "tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/__tests__/",
    "db:setup": "psql \"$DATABASE_URL\" -f schema.sql",
    "deploy": "wrangler deploy",
    "demo": "tsx src/demo.ts",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "grammy": "1.44.0",
    "hono": "4.12.27",
    "postgres": "3.4.9",
    "toucan-js": "4.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "bun-types": "^1.3.14",
    "eslint": "^10.6.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "wrangler": "4.106.0"
  }
}
