{
  "name": "casino-bot-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:setup": "psql \"$DATABASE_URL\" -f schema.sql",
    "deploy": "wrangler deploy",
    "demo": "tsx src/demo.ts",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "grammy": "^1.30.0",
    "hono": "^4.12.27",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  }
}
