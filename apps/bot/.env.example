# Supabase Postgres connection string (direct, not pooler)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Bot encryption key (32-byte hex)
TOKEN_ENC_KEY=

# Admin API key (protects /bot/api/* endpoints)
ADMIN_API_KEY=

# IP hashing salt
IP_HASH_SALT=

# Telegram Login widget bot
LOGIN_BOT_TOKEN=
LOGIN_BOT_USERNAME=

# Platform bot for Telegram Stars billing (optional)
PLATFORM_BOT_TOKEN=
PLATFORM_WEBHOOK_SECRET=

# Public base URL
PUBLIC_BASE_URL=https://yourrank.site

# Discord monitoring webhook (optional, error reporting + cron summaries)
DISCORD_MONITORING_WEBHOOK=

# Session cookie domain (default: .yourrank.site)
SESSION_COOKIE_DOMAIN=.yourrank.site

# Allow dev-only login endpoint (NEVER enable in production)
ALLOW_DEV_LOGIN=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=
