# Local dev: start Postgres with `docker compose up -d`, then set:
# CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://postgres:postgres@localhost:5432/yourrank
#
# Supabase Postgres connection string (direct, not pooler). Used as a fallback
# when Hyperdrive is not bound.
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# NOWPayments API (optional, for crypto billing)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Resend for transactional email (optional)
RESEND_API_KEY=
MAIL_FROM=YourRank <hey@yourrank.site>

# Pro plan price in USD (optional, default 29)
PRO_PRICE_USD=29

# Lead webhook URL (optional, Discord/Slack)
LEAD_WEBHOOK_URL=

# Telegram webhook URL (optional, for bot integration notifications)
TELEGRAM_WEBHOOK_URL=

# Discord monitoring webhook (REQUIRED for production — cron failures are silent without this)
DISCORD_MONITORING_WEBHOOK=

# Session cookie domain (default: .yourrank.site)
SESSION_COOKIE_DOMAIN=.yourrank.site

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Admin TOTP secret (base32, for 2FA)
ADMIN_TOTP_SECRET=

# Cloudflare Zone ID (for cache purge)
CF_ZONE_ID=

# ENCRYPTION_KEY (32-byte hex, for token encryption at rest)
ENCRYPTION_KEY=
