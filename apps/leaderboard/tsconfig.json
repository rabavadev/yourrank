{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../../shared",
    "rootDir": "../../shared",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "declaration": false,
    "removeComments": false,
    "types": ["node"]
  },
  "include": ["../../shared"],
  "exclude": ["node_modules", "dist", "src", "../../shared/__tests__"]
}
